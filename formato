<!DOCTYPE html>

<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reporte Área Frío — Frutos Tropicales</title>
<style>
  /* ── PANTALLA: controles ── */
  @media screen {
    body { font-family: Arial, sans-serif; background: #f0f4f8; margin: 0; padding: 20px; }
    .controls {
      background: #fff; border-radius: 16px; padding: 24px;
      margin-bottom: 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      max-width: 900px; margin-left: auto; margin-right: auto;
    }
    .controls-title {
      font-size: 18px; font-weight: 800; color: #1a2e1a; margin-bottom: 20px;
      display: flex; align-items: center; gap: 10px;
    }
    .ctrl-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 20px; }
    .ctrl-group { display: flex; flex-direction: column; gap: 6px; }
    .ctrl-group label { font-size: 11px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; }
    .ctrl-group input, .ctrl-group select {
      padding: 10px 14px; border: 2px solid #e2e8f0; border-radius: 10px;
      font-size: 14px; font-family: Arial, sans-serif; outline: none;
      transition: border-color 0.2s;
    }
    .ctrl-group input:focus, .ctrl-group select:focus { border-color: #16a34a; }
    .btn-load {
      background: #16a34a; color: #fff; border: none; border-radius: 10px;
      padding: 11px 24px; font-size: 14px; font-weight: 700; cursor: pointer;
      font-family: Arial, sans-serif; transition: all 0.2s;
    }
    .btn-load:hover { background: #15803d; }
    .btn-print {
      background: #2563eb; color: #fff; border: none; border-radius: 10px;
      padding: 11px 24px; font-size: 14px; font-weight: 700; cursor: pointer;
      font-family: Arial, sans-serif; transition: all 0.2s; margin-left: 8px;
    }
    .btn-print:hover { background: #1d4ed8; }
    .status-msg { font-size: 13px; color: #64748b; margin-top: 10px; min-height: 18px; }
    .preview-wrap { max-width: 900px; margin: 0 auto; }
  }

/* ── FORMULARIO (pantalla y PDF) ── */
.form-page {
background: #fff;
width: 210mm;
min-height: 297mm;
margin: 0 auto;
padding: 10mm 12mm;
box-sizing: border-box;
font-family: Arial, sans-serif;
font-size: 9pt;
color: #000;
}

@media screen {
.form-page {
box-shadow: 0 4px 24px rgba(0,0,0,0.12);
border-radius: 4px;
margin-bottom: 20px;
}
}

/* ENCABEZADO */
.header-table {
width: 100%; border-collapse: collapse; margin-bottom: 4mm;
}
.header-table td { vertical-align: middle; padding: 0; }
.company-name {
font-size: 13pt; font-weight: 900; color: #1a5c25; line-height: 1.1;
}
.company-sub { font-size: 7pt; color: #555; }
.doc-title {
text-align: center; font-size: 11pt; font-weight: 900;
text-transform: uppercase; letter-spacing: 0.5px;
border: 2px solid #000; padding: 3mm 2mm;
}
.doc-code { text-align: right; font-size: 7pt; color: #555; line-height: 1.6; }

/* INFO SUPERIOR */
.info-row {
display: flex; gap: 4mm; margin-bottom: 3mm;
}
.info-box {
border: 1.5px solid #000; border-radius: 3px;
padding: 2mm 3mm; flex: 1;
}
.info-box-label { font-size: 7pt; color: #555; font-weight: 700; text-transform: uppercase; }
.info-box-value { font-size: 11pt; font-weight: 900; color: #000; margin-top: 1mm; }

/* ACCIONES CORRECTIVAS - mini box arriba derecha */
.acciones-box {
border: 1.5px solid #000; border-radius: 3px;
padding: 2mm 3mm; font-size: 7.5pt; line-height: 1.5;
}
.acciones-box strong { font-size: 8pt; }

/* TABLA PRINCIPAL */
.main-table {
width: 100%; border-collapse: collapse;
margin-bottom: 3mm;
}
.main-table th, .main-table td {
border: 1px solid #333;
text-align: center;
padding: 0;
vertical-align: middle;
}
.main-table th {
background: #d4edda;
font-size: 7.5pt;
font-weight: 700;
padding: 2mm 1mm;
line-height: 1.3;
}
.main-table th.area-header {
background: #1a5c25;
color: #fff;
font-size: 8pt;
padding: 2mm;
}
.main-table td {
height: 7mm;
font-size: 8.5pt;
}
.main-table td.hora-cell {
font-weight: 700;
background: #f0f9f3;
font-size: 9pt;
}
.main-table td.temp-ok { color: #166534; font-weight: 700; }
.main-table td.temp-alerta { color: #92400e; font-weight: 700; background: #fef3c7; }
.main-table td.temp-critico { color: #991b1b; font-weight: 700; background: #fee2e2; }
.main-table td.empty { background: #fafafa; }
.main-table td.obs-cell { font-size: 7.5pt; text-align: left; padding: 1mm 2mm; }

/* ACCIONES CORRECTIVAS ABAJO */
.acciones-bottom {
border: 1.5px solid #000; border-radius: 3px;
padding: 2mm 3mm; margin-bottom: 3mm; min-height: 12mm;
}
.acciones-bottom-title { font-size: 8pt; font-weight: 700; text-transform: uppercase; margin-bottom: 2mm; }

/* PARAMETROS */
.params-table {
width: 55%; border-collapse: collapse; margin: 0 auto;
margin-bottom: 4mm;
}
.params-table th, .params-table td {
border: 1px solid #333; padding: 1.5mm 2mm;
font-size: 7.5pt; text-align: center;
}
.params-table th { background: #d4edda; font-weight: 700; }

/* FIRMAS */
.firmas-row {
display: flex; justify-content: space-between; gap: 8mm;
margin-top: 3mm;
}
.firma-box { flex: 1; text-align: center; }
.firma-line { border-top: 1.5px solid #000; padding-top: 2mm; font-size: 7.5pt; }
.firma-title { font-size: 7pt; color: #555; margin-bottom: 6mm; }

/* PIE */
.footer-doc {
text-align: center; font-size: 6.5pt; color: #666;
margin-top: 3mm; border-top: 1px solid #ccc; padding-top: 2mm;
}

/* ── IMPRESIÓN ── */
@media print {
body { background: #fff; padding: 0; margin: 0; }
.controls { display: none !important; }
.form-page {
width: 100%; box-shadow: none; border-radius: 0;
padding: 8mm 10mm; margin: 0;
}
@page { size: A4; margin: 0; }
}
</style>

</head>
<body>

<!-- CONTROLES (solo pantalla) -->

