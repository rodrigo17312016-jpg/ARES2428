<!-- FORMULARIO IMPRIMIBLE -->

<div class="preview-wrap">
<div class="form-page" id="formPage">

  <!-- ENCABEZADO -->

  <table class="header-table">
    <tr>
      <td style="width:30%">
        <div class="company-name">FRUTOS TROPICALES</div>
        <div class="company-sub">PERU EXPORT S.A.C.</div>
      </td>
      <td style="width:40%">
        <div class="doc-title">CONTROL DE TEMPERATURAS<br>ÁREA FRÍO</div>
      </td>
      <td style="width:30%;padding-left:4mm">
        <div class="doc-code">
          Código: FTP-CAL-001<br>
          Versión: 03<br>
          F. Emisión: 15/03/2026
        </div>
      </td>
    </tr>
  </table>

  <!-- INFO: Fecha, Juliano, Turno + Acciones correctivas -->

  <table style="width:100%;border-collapse:collapse;margin-bottom:3mm;">
    <tr>
      <td style="width:65%;vertical-align:top;padding-right:3mm;">
        <div class="info-row">
          <div class="info-box">
            <div class="info-box-label">Fecha</div>
            <div class="info-box-value" id="displayFecha">—</div>
          </div>
          <div class="info-box" style="max-width:28mm;">
            <div class="info-box-label">Juliano</div>
            <div class="info-box-value" id="displayJuliano">—</div>
          </div>
          <div class="info-box">
            <div class="info-box-label">Turno</div>
            <div class="info-box-value" id="displayTurno">—</div>
          </div>
        </div>
        <div class="info-row">
          <div class="info-box">
            <div class="info-box-label">Responsable / Supervisor</div>
            <div class="info-box-value" id="displayResponsable" style="font-size:9pt;">—</div>
          </div>
        </div>
      </td>
      <td style="width:35%;vertical-align:top;">
        <div class="acciones-box">
          <strong>ACCIONES CORRECTIVAS:</strong><br>
          Si la temperatura de la sala se encuentra fuera del rango establecido,
          comunicar al Jefe de Área de inmediato y registrar la acción tomada
          al final de este formato.
        </div>
      </td>
    </tr>
  </table>

  <!-- TABLA PRINCIPAL -->

  <table class="main-table" id="mainTable">
    <thead>
      <tr>
        <th rowspan="2" style="width:12mm">HORA</th>
        <th class="area-header" colspan="1">TEMPERATURA<br>DE PRODUCTO<br><span style="font-size:6.5pt;font-weight:400">(°C)</span></th>
        <th class="area-header" colspan="1" style="background:#2d7a3a;">SALA DE<br>EMPAQUE<br><span style="font-size:6.5pt;font-weight:400">(°C)</span></th>
        <th class="area-header" colspan="1" style="background:#1a5c25;">CÁMARA DE<br>PRODUCTO<br>TERMINADO<br><span style="font-size:6.5pt;font-weight:400">(°C)</span></th>
        <th class="area-header" colspan="1" style="background:#2d7a3a;">SALA DE<br>DESPACHO<br><span style="font-size:6.5pt;font-weight:400">(°C)</span></th>
        <th rowspan="2" style="min-width:35mm;background:#e8f5e9;color:#000;">OBSERVACIONES</th>
      </tr>
      <tr>
        <th style="font-size:7pt;color:#555;padding:1mm">T (°C)</th>
        <th style="font-size:7pt;color:#555;padding:1mm">T (°C)</th>
        <th style="font-size:7pt;color:#555;padding:1mm">T (°C)</th>
        <th style="font-size:7pt;color:#555;padding:1mm">T (°C)</th>
      </tr>
    </thead>
    <tbody id="tableBody">
      <!-- Se llena dinámicamente -->
    </tbody>
  </table>

  <!-- ACCIONES CORRECTIVAS ABAJO -->

  <div class="acciones-bottom">
    <div class="acciones-bottom-title">Acciones correctivas tomadas:</div>
    <div id="accionesTexto" style="font-size:8pt;color:#333;min-height:8mm;"></div>
  </div>

  <!-- PARAMETROS -->

  <table class="params-table">
    <thead>
      <tr>
        <th colspan="2">PARÁMETROS DE TEMPERATURA (°C)</th>
      </tr>
      <tr>
        <th>ZONA</th>
        <th>RANGO DE TEMPERATURA (°C)</th>
      </tr>
    </thead>
    <tbody>
      <tr><td>Temperatura de Producto</td><td>-18 a -20</td></tr>
      <tr><td>Sala de Empaque</td><td>0 a 5</td></tr>
      <tr><td>Cámara de Producto Terminado</td><td>-18 a -20</td></tr>
      <tr><td>Sala de Despacho</td><td>0 a 5</td></tr>
    </tbody>
  </table>

  <!-- FIRMAS -->

  <div class="firmas-row">
    <div class="firma-box">
      <div class="firma-title">Inspector de Aseguramiento de la Calidad</div>
      <div class="firma-line" id="firmaInspector">_______________________________</div>
    </div>
    <div class="firma-box">
      <div class="firma-title">VºBº Coordinador de Site</div>
      <div class="firma-line">_______________________________</div>
    </div>
  </div>

  <!-- PIE -->

  <div class="footer-doc">
    DOCUMENTO CONTROLADO — PROHIBIDA SU REPRODUCCIÓN SIN AUTORIZACIÓN DE FRUTOS TROPICALES PERU EXPORT S.A.C.
  </div>

</div>
</div>

<script>
const SB_URL = 'https://obnvrfvcujsrmifvlqni.supabase.co';
const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9ibnZyZnZjdWpzcm1pZnZscW5pIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM1MDY3OTUsImV4cCI6MjA4OTA4Mjc5NX0.A7BilSrDzqe2rqz1Kh8fg5t-GVNxrLGYJK4IaMlVtBs';

// Mapeo de áreas de la app a columnas del formulario
const AREAS_FRIO = {
  'TEMPERATURA PRODUCTO':         'producto',
  'EMPAQUE':                      'empaque',
  'CAMARA DE PRODUCTO TERMINADO': 'camara',
  'DESPACHO':                     'despacho',
};

// Rangos para colorear
const RANGOS = {
  'producto': { limite: -18, critico: -13 },
  'empaque':  { limite: 5,   critico: 10  },
  'camara':   { limite: -20, critico: -15 },
  'despacho': { limite: 5,   critico: 10  },
};

// Calcular día juliano
function getDayOfYear(date) {
  const start = new Date(date.getFullYear(), 0, 0);
  const diff = date - start;
  const oneDay = 1000 * 60 * 60 * 24;
  return Math.floor(diff / oneDay);
}

// Formatear fecha para mostrar
function formatFecha(dateStr) {
  const [y, m, d] = dateStr.split('-');
  return `${d}/${m}/${y}`;
}

// Init: set today's date
window.onload = () => {
  const now = new Date();
  const today = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
  document.getElementById('ctrlFecha').value = today;
  // Auto-detect turno
  const h = now.getHours();
  document.getElementById('ctrlTurno').value = (h >= 6 && h <= 18) ? 'DIA' : 'NOCHE';
};

async function cargarDatos() {
  const fecha    = document.getElementById('ctrlFecha').value;
  const turno    = document.getElementById('ctrlTurno').value;
  const responsable = document.getElementById('ctrlResponsable').value;
  const msg      = document.getElementById('statusMsg');

  if (!fecha) { msg.textContent = '⚠ Selecciona una fecha primero.'; return; }

  msg.textContent = '⏳ Consultando Supabase...';

  // Actualizar encabezado del formulario
  const dateObj = new Date(fecha + 'T12:00:00');
  document.getElementById('displayFecha').textContent = formatFecha(fecha);
  document.getElementById('displayJuliano').textContent = getDayOfYear(dateObj);
  document.getElementById('displayTurno').textContent = turno === 'DIA' ? 'DÍA' : 'NOCHE';
  document.getElementById('displayResponsable').textContent = responsable;
  document.getElementById('firmaInspector').textContent = responsable;

  try {
    // Traer todos los registros de las 4 áreas del formulario en esa fecha
    const areas = Object.keys(AREAS_FRIO).map(a => `area=eq.${encodeURIComponent(a)}`).join('&');
    const url = `${SB_URL}/rest/v1/registros_temperatura?fecha=eq.${fecha}&or=(${Object.keys(AREAS_FRIO).map(a=>`area.eq.${a}`).join(',')})&order=hora.asc`;

    const res = await fetch(url, {
      headers: { 'apikey': SB_KEY, 'Authorization': `Bearer ${SB_KEY}` }
    });

    let data = [];
    if (res.ok) {
      data = await res.json();
      // Filtrar por turno
      data = data.filter(r => {
        const h = parseInt(r.hora.split(':')[0]);
        return turno === 'DIA' ? (h >= 6 && h <= 18) : (h >= 19 || h <= 5);
      });
    }

    msg.textContent = `✅ ${data.length} registros encontrados para ${formatFecha(fecha)} — Turno ${turno}`;
    buildTable(data, turno);

  } catch(e) {
    msg.textContent = '❌ Error al conectar con Supabase: ' + e.message;
  }
}

function buildTable(data, turno) {
  // Generar las horas del turno seleccionado
  let horas = [];
  if (turno === 'DIA') {
    for (let h = 6; h <= 18; h++) horas.push(`${String(h).padStart(2,'0')}:00`);
  } else {
    for (let h = 19; h <= 23; h++) horas.push(`${String(h).padStart(2,'0')}:00`);
    for (let h = 0; h <= 5; h++)  horas.push(`${String(h).padStart(2,'0')}:00`);
  }

  // Organizar datos por hora y área
  // Para cada hora, buscar el registro más cercano (mismo hour)
  const byHoraArea = {};
  data.forEach(r => {
    const hh = r.hora.slice(0,2);
    if (!byHoraArea[hh]) byHoraArea[hh] = {};
    const col = AREAS_FRIO[r.area];
    if (col) byHoraArea[hh][col] = r;
  });

  // Recopilar observaciones y acciones correctivas
  const observaciones = [];
  const acciones = [];

  const tbody = document.getElementById('tableBody');
  tbody.innerHTML = '';

  horas.forEach(hora => {
    const hh = hora.slice(0,2);
    const regs = byHoraArea[hh] || {};
    const tr = document.createElement('tr');

    // Columna hora
    const tdHora = document.createElement('td');
    tdHora.className = 'hora-cell';
    tdHora.textContent = hora;
    tr.appendChild(tdHora);

    // Columnas de temperatura
    ['producto','empaque','camara','despacho'].forEach(col => {
      const td = document.createElement('td');
      const r = regs[col];
      if (r) {
        td.textContent = r.temperatura + '°C';
        const c = getColorClass(col, r.temperatura);
        td.className = c;
        if (r.observaciones && r.observaciones.trim()) {
          observaciones.push(`${hora} (${col.toUpperCase()}): ${r.observaciones}`);
        }
        if (r.estado === 'ALERTA' || r.estado === 'CRITICO') {
          acciones.push(`${hora} — ${r.area}: ${r.temperatura}°C (${r.estado})`);
        }
      } else {
        td.className = 'empty';
        td.textContent = '—';
      }
      tr.appendChild(td);
    });

    // Columna observaciones (agrupadas por hora)
    const tdObs = document.createElement('td');
    tdObs.className = 'obs-cell';
    const obsHora = Object.values(regs)
      .filter(r => r && r.observaciones && r.observaciones.trim())
      .map(r => r.observaciones.trim())
      .join(' / ');
    tdObs.textContent = obsHora || '';
    tr.appendChild(tdObs);

    tbody.appendChild(tr);
  });

  // Acciones correctivas
  const acText = document.getElementById('accionesTexto');
  if (acciones.length > 0) {
    acText.innerHTML = acciones.map(a => `• ${a}`).join('<br>');
  } else {
    acText.textContent = 'Sin alertas registradas en este turno.';
  }
}

function getColorClass(col, temp) {
  const r = RANGOS[col];
  if (!r) return '';
  if (r.limite < 0) {
    if (temp > r.critico) return 'temp-critico';
    if (temp > r.limite)  return 'temp-alerta';
  } else {
    if (temp > r.critico) return 'temp-critico';
    if (temp > r.limite)  return 'temp-alerta';
  }
  return 'temp-ok';
}
</script>

</body>
